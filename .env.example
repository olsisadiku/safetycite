# Which live engine to use: "local" (Hugging Face on MPS/CUDA/CPU) or "mint" (remote)
SAFETYCITE_BACKEND=local

# Base model for all adapters (small + cheap by default)
SAFETYCITE_BASE_MODEL=Qwen/Qwen3-0.6B

# --- MinT (only needed when SAFETYCITE_BACKEND=mint) ---
# Self-service key from macaron.im/mindlab/mint. Requires `pip install tinker==0.6.3`.
TINKER_BASE_URL=https://mint.macaron.xin/
TINKER_API_KEY=sk-mint-xxxxxxxxxxxxxxxxxxxxxxxx
